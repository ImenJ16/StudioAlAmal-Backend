@page "/gallery"
@using StudioAlAmalWeb.Models
@using StudioAlAmalWeb.Services
@inject ContentService ContentService

<PageTitle>Gallery - Studio Al Amal</PageTitle>

<div class="gallery-container">
    <h1>Our Portfolio</h1>

    <!-- Category Filter -->
    <div class="category-filter">
        <button class="btn @(selectedCategory == null ? "btn-active" : "btn-outline")" @onclick="FilterAll">
            All
        </button>
        <button class="btn @(selectedCategory == "Wedding" ? "btn-active" : "btn-outline")" @onclick="FilterWedding">
            Wedding
        </button>
        <button class="btn @(selectedCategory == "Portrait" ? "btn-active" : "btn-outline")" @onclick="FilterPortrait">
            Portrait
        </button>
        <button class="btn @(selectedCategory == "Event" ? "btn-active" : "btn-outline")" @onclick="FilterEvent">
            Event
        </button>
    </div>

    <!-- Photo Grid -->
    <div class="photo-grid-large">
        @if (filteredPhotos.Any())
        {
            @foreach (var photo in filteredPhotos)
            {
                <div class="photo-item" @onclick="() => OpenPhoto(photo)">
                    <img src="@(photo.ThumbnailUrl ?? photo.ImageUrl)" alt="@photo.Title" />
                    <div class="photo-info">
                        <h3>@photo.Title</h3>
                        @if (!string.IsNullOrEmpty(photo.Description))
                        {
                            <p>@photo.Description</p>
                        }
                        @if (!string.IsNullOrEmpty(photo.Category))
                        {
                            <span class="badge">@photo.Category</span>
                        }
                    </div>
                </div>
            }
        }
        else if (isLoading)
        {
            <p>Loading photos...</p>
        }
        else
        {
            <p>No photos found in this category.</p>
        }
    </div>
</div>

@code {
    private List<Photo> photos = new();
    private List<Photo> filteredPhotos = new();
    private string? selectedCategory = null;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadPhotosAsync();
    }

    private async Task LoadPhotosAsync()
    {
        isLoading = true;
        photos = await ContentService.GetPhotosAsync(activeOnly: true);
        filteredPhotos = photos;
        isLoading = false;
    }

    private void FilterAll()
    {
        selectedCategory = null;
        filteredPhotos = photos;
    }

    private void FilterWedding()
    {
        selectedCategory = "Wedding";
        filteredPhotos = photos.Where(p => p.Category == "Wedding").ToList();
    }

    private void FilterPortrait()
    {
        selectedCategory = "Portrait";
        filteredPhotos = photos.Where(p => p.Category == "Portrait").ToList();
    }

    private void FilterEvent()
    {
        selectedCategory = "Event";
        filteredPhotos = photos.Where(p => p.Category == "Event").ToList();
    }

    private void OpenPhoto(Photo photo)
    {
        // In future: open modal with full image
        Console.WriteLine($"Opening photo: {photo.Title}");
    }
}